# Runtime
NODE_ENV=development
PORT=8870

# Database for local host access. Docker Compose overrides the backend container
# to use postgres:5432 internally and exposes this host port.
DATABASE_URL=postgres://postgres:postgres@localhost:5438/workflowbe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workflowbe
POSTGRES_HOST_PORT=5438

# Redis for local host access. Docker Compose overrides the backend container
# to use redis:6379 internally and exposes this host port.
REDIS_URL=redis://localhost:6385
REDIS_HOST_PORT=6385

# JWT secret (HS256) and other secrets
JWT_SECRET=dev-only-jwt-secret-please-rotate-in-prod-32chars

# HTTP / CORS / logging
COOKIE_DOMAIN=localhost
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=debug
